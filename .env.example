# مسیر دیتابیس SQLite - نیازی به تغییر نیست
DATABASE_URL="file:./dev.db"

# یک رشته‌ی رندوم برای امنیت session ها.
# می‌تونی هر متن رندوم طولانی بذاری، یا با دستور زیر بسازی:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="change-this-to-a-random-string"

# آدرس سایت روی سیستم خودت - برای تست local تغییر نده
NEXTAUTH_URL="http://localhost:3000"

# کلید API از داشبورد AvalAI (chat.avalai.ir/platform/home)
AVALAI_API_KEY="کلید-خودت-را-اینجا-بگذار"
